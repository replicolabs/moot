{
  "_metadata": {
    "major_version": 2,
    "minor_version": 1
  },
  "display_information": {
    "name": "Moot",
    "description": "Slack-native treasury and execution for stablecoins and crypto, backed by on-chain multisigs.",
    "background_color": "#1a1a2e"
  },
  "features": {
    "bot_user": {
      "display_name": "Moot",
      "always_online": true
    },
    "agent_view": {
      "agent_description": "Moot turns Slack proposals into real on-chain multisig transactions. It can draft and execute, but every dollar still needs real member signatures before it moves.",
      "suggested_prompts": [
        {
          "title": "Pay a vendor",
          "message": "@moot pay Ada 200 USDC from Ops for the logo work"
        },
        {
          "title": "Check a treasury",
          "message": "@moot what's the balance of Ops?"
        }
      ]
    },
    "slash_commands": [
      {
        "command": "/moot",
        "description": "Manage treasuries, proposals, and approvals",
        "usage_hint": "treasury new | propose ... | rules <treasury> | check <treasury> <draft>",
        "should_escape": false
      }
    ]
  },
  "oauth_config": {
    "redirect_urls": [
      "https://YOUR_BACKEND_DOMAIN/slack/oauth_redirect"
    ],
    "scopes": {
      "bot": [
        "chat:write",
        "app_mentions:read",
        "channels:history",
        "channels:read",
        "reactions:read",
        "users:read",
        "usergroups:read",
        "im:write",
        "commands"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "app_mention",
        "message.channels",
        "reaction_added",
        "reaction_removed"
      ]
    },
    "interactivity": {
      "is_enabled": true
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  }
}
