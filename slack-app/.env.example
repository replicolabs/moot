# From the Slack app's "Basic Information" page (already exists for the app
# you created earlier -- these two were never needed until now since the app
# only ran with a single fixed bot token).
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# App-level values, unchanged by going multi-tenant (one per Slack app, not per install).
SLACK_SIGNING_SECRET=
SLACK_APP_TOKEN=

# CSRF-protection secret for the OAuth install flow. Any random string works.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SLACK_STATE_SECRET=

# Port Bolt's internal OAuth install/redirect server listens on (behind your reverse proxy).
SLACK_OAUTH_PORT=3000

# Must match mcp-server's MCP_INTERNAL_TOKEN exactly.
MCP_INTERNAL_TOKEN=
MCP_SERVER_URL=http://localhost:8788/mcp
SIGNING_WEBVIEW_URL=http://localhost:8787/webview

ANTHROPIC_API_KEY=
