# Shared secret with slack-app -- must be identical on both processes.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MCP_INTERNAL_TOKEN=

# Signs short-lived webview capability tokens (wallet-link + approval pages).
# Generate the same way as MCP_INTERNAL_TOKEN, but as a separate value.
WEBVIEW_TOKEN_SECRET=

# Localhost-only port for the /mcp JSON-RPC endpoint (slack-app is the only caller).
MCP_INTERNAL_PORT=8788

# Public port for /webview, /api/*, /github/setup, /health.
MCP_SERVER_PORT=8787

# GitHub App used for the merge-proposal feature. One App, many per-workspace
# installations (see the github_installations table) -- do NOT set an
# installation id here, that's resolved per (team, owner) at runtime.
GITHUB_APP_ID=
# Either the PEM contents inline, or a path to the PEM file:
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_PRIVATE_KEY_PATH=

# Optional: override the Solana cluster/RPC (defaults to devnet).
# SOLANA_CLUSTER=devnet
# SOLANA_RPC_URL=

# Optional: override where Moot's own signing keys live (defaults to .keys/moot.json, .keys/payer.json).
# MOOT_PROPOSER_KEYPAIR_PATH=
# MOOT_PAYER_KEYPAIR_PATH=
